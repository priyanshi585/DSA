Question:
You are given an integer array coins representing coins of different denominations and an integer amount representing a total amount of money.
Return the number of combinations that make up that amount. If that amount of money cannot be made up by any combination of the coins, return 0.
You may assume that you have an infinite number of each kind of coin.
The answer is guaranteed to fit into a signed 32-bit integer.


Example 1:
Input: amount = 5, coins = [1,2,5]
Output: 4
Explanation: there are four ways to make up the amount:
5=5
5=2+2+1
5=2+1+1+1
5=1+1+1+1+1


Example 2:
Input: amount = 3, coins = [2]
Output: 0
Explanation: the amount of 3 cannot be made up just with coins of 2.


Example 3:
Input: amount = 10, coins = [10]
Output: 1
 

Constraints:
1 <= coins.length <= 300
1 <= coins[i] <= 5000
All the values of coins are unique.
0 <= amount <= 5000


Code:
I) Recursive Solution:
class Solution {
public:
    
    int countWays(int i , int target , vector<int>& coins){
        if(target == 0) return 1;
        
        if(i==0){
            if(target % coins[i] == 0) return 1;
            else return 0;
        }

        int pick = 0;
        if(coins[i]<=target) pick =  countWays(i , target-coins[i] , coins);
        int notPick = countWays(i-1 , target, coins);
        return pick + notPick ;
        
    }
    
    int change(int amount, vector<int>& coins) {
        int n = coins.size();
        return countWays(n-1 , amount, coins);
    }
};


II) Memoized Solution:
class Solution {
public:
    
    int countWays(int i , int target , vector<int>& coins, vector<vector<int>> &dp){
        if(target == 0) return 1;

        if(i==0){
            if(target % coins[i] == 0) return 1;
            else return 0;
        }

        if(dp[i][target] != -1) return dp[i][target];

        int pick = 0;
        if(coins[i]<=target) pick =  countWays(i , target-coins[i] , coins, dp);
        int notPick = countWays(i-1 , target, coins, dp);
        return dp[i][target] = pick + notPick ;
        
    }
    
    int change(int amount, vector<int>& coins) {
        int n = coins.size();
        vector<vector<int>> dp(n , vector<int>(amount+1 , -1));
        return countWays(n-1 , amount, coins, dp);
    }
};


III) Tabulation Solution:
class Solution {
public: 
    int change(int amount, vector<int>& coins) {
        int n = coins.size();
        vector<vector<unsigned long long>> dp(n , vector<unsigned long long>(amount+1 , 0));


        for(int i = 0 ; i<n ; i++) dp[i][0] = 1;
        for(int j = 0 ; j<= amount; j++){
            if(j % coins[0] == 0) dp[0][j] = 1;
            else dp[0][j] = 0;
         }

        for(int i = 1; i<n ; i++){
            for(int j = 1; j<= amount ; j++){
                unsigned long long pick = 0;
                if(coins[i]<=j) pick =  dp[i][j-coins[i]];
                unsigned long long notPick = dp[i-1][j];
                dp[i][j] = (pick + notPick);
            }
        }
        return dp[n-1][amount];
    }
};


IV) Space Optimized Solution:
class Solution {
public: 
    int change(int amount, vector<int>& coins) {
        int n = coins.size();
        vector<unsigned long long> prev(amount+1 , 0);
        vector<unsigned long long> curr(amount+1 , 0);


        for(int i = 0 ; i<n ; i++) curr[0] = 1;
        for(int j = 0 ; j<= amount; j++){
            if(j % coins[0] == 0) prev[j] = 1;
            else prev[j] = 0;
         }

        for(int i = 1; i<n ; i++){
            for(int j = 1; j<= amount ; j++){
                unsigned long long pick = 0;
                if(coins[i]<=j) pick =  curr[j-coins[i]];
                unsigned long long notPick = prev[j];
                curr[j] = (pick + notPick);
            }
            prev = curr;
        }
        return prev[amount];
    }
};
